# Local environment variables example
# Copy this file to .env and fill in real values.

# Existing backend variables
WEBHOOK_VERIFY_TOKEN=replace-with-webhook-verify-token
META_APP_SECRET=replace-with-meta-app-secret
SEND_MESSAGE_API_KEY=replace-with-send-message-api-key

# App base URLs
PORTAL_BASE_URL=http://localhost:3000
BACKOFFICE_BASE_URL=http://localhost:3001

# Cognito Hosted UI / App client
COGNITO_DOMAIN=replace-with-cognito-domain
COGNITO_APP_CLIENT_ID=replace-with-cognito-app-client-id

# Social login providers
COGNITO_GOOGLE_CLIENT_ID=replace-with-google-client-id
COGNITO_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
COGNITO_FACEBOOK_APP_ID=replace-with-facebook-app-id
COGNITO_FACEBOOK_APP_SECRET=replace-with-facebook-app-secret
