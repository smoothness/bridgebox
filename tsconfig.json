{
	"extends": "@tsconfig/node18/tsconfig.json",
	"exclude": ["packages"],
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "node",
		"types": ["node"],
		// Required for .ts extension imports in scripts/ (tsx resolves them at runtime)
		"allowImportingTsExtensions": true,
		"noEmit": true
	}
}
